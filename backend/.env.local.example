# ───────────────────────────────────────────────────────────────
#  NeoBank Backend — environment template
# ───────────────────────────────────────────────────────────────
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# Load before running:  set -a; . ./.env.local; set +a  &&  mvn spring-boot:run
#
# If unset, application.properties falls back to a local in-memory H2 DB,
# so the app boots with zero configuration for quick local dev.

# ─── Database (omit all DATABASE_* to use the local H2 default) ───
DATABASE_URL=jdbc:postgresql://<host>:5432/<database>
DATABASE_DRIVER=org.postgresql.Driver
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
JPA_DDL_AUTO=update

# ─── JWT — Base64, >= 256 bits. Generate: openssl rand -base64 48 ───
JWT_SECRET=

# ─── Email ───
MAIL_USERNAME=
MAIL_PASSWORD=
