## Database Schema (Core Tables)

```sql
-- Users
users (id, email, username, password_hash, full_name, role, created_at)

-- Accounts
accounts (id, user_id, account_number, type[CHECKING/SAVINGS], status, created_at)

-- Ledger (double-entry accounting)
ledger_entries (id, account_id, transaction_id, type[DEBIT/CREDIT], amount, balance_after, created_at)

-- Transactions
transactions (id, from_account_id, to_account_id, amount, type, status, reference, description, created_at)

-- PayFlow
payflow_requests (id, from_user_id, to_user_id, amount, status[PENDING/ACCEPTED/DECLINED], note, created_at)
payflow_payments (id, user_id, type[BOOKING/BILL/RECHARGE], amount, status[PENDING/CONFIRMED/FAILED], reference_number, metadata_json, created_at)

-- ClearLedger
expenses (id, user_id, amount, category, description, date, created_at)
budgets (id, user_id, category, limit_amount, period[MONTHLY/WEEKLY], created_at)
```

